---
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign lang = site.lang | default: site.default_lang %}
{% assign lang_segment = '/' | append: lang | append: '/' %}
{% for p in site.pages %}
  {% if p.namespace and p.layout == 'default' and p.sitemap != false and p.noindex != true and p.alias != true %}
    {% assign loc = p.url | absolute_url %}
    {% if lang != site.default_lang %}
      {% unless loc contains lang_segment %}
        {% assign loc = site.url | append: '/' | append: lang | append: p.url %}
      {% endunless %}
    {% endif %}
  <url>
    <loc>{{ loc }}</loc>
    <changefreq>monthly</changefreq>
    <priority>{% assign slash_count = p.url | split: '/' | size %}{% if slash_count <= 3 %}0.9{% else %}0.7{% endif %}</priority>
  </url>
  {% endif %}
{% endfor %}
</urlset>
